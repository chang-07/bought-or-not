# =============================================================================
# Backend Environment Variables
# Copy this file to .env in the backend/ directory and fill in the values.
# =============================================================================

# ---------------------------------------------------------------------------
# Django (Required)
# ---------------------------------------------------------------------------

# SECRET KEY — Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# In production, this MUST be set. Never commit your real key.
DJANGO_SECRET_KEY=

# Set to "True" for local development, "False" (or unset) for production
DJANGO_DEBUG=True

# Comma-separated list of allowed hostnames. Use "*" for local dev only.
# Production: your-render-app.onrender.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Database (Required for production)
# ---------------------------------------------------------------------------

# Local dev uses SQLite by default. Production should use PostgreSQL.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Example (Render PostgreSQL): postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# ---------------------------------------------------------------------------
# Frontend CORS (Required for production)
# ---------------------------------------------------------------------------

# Comma-separated list of frontend URLs allowed to make cross-origin requests.
# Local dev defaults to localhost:3000.
# Production: https://your-netlify-site.netlify.app
FRONTEND_URLS=http://localhost:3000,http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# Celery / Redis (Required for background tasks)
# ---------------------------------------------------------------------------

# Local dev: Redis must be running on localhost:6379
# Production: use a Redis add-on (e.g., Render Redis, Upstash, Redis Cloud)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# SnapTrade (Required for trading features)
# ---------------------------------------------------------------------------

SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# ---------------------------------------------------------------------------
# Finnhub (Required for stock price data)
# ---------------------------------------------------------------------------

FINNHUB_API_KEY=

# ---------------------------------------------------------------------------
# Cloudflare R2 / AWS S3 (Optional — for pitch deck file storage)
# ---------------------------------------------------------------------------
# If not set, files are stored locally (lost on redeploy for ephemeral hosts).

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
# For Cloudflare R2: https://<account-id>.r2.cloudflarestorage.com
AWS_S3_ENDPOINT_URL=

# ---------------------------------------------------------------------------
# Superuser (Optional — auto-created on container start)
# ---------------------------------------------------------------------------

SUPERUSER_USERNAME=admin
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=
